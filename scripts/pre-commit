#!/usr/bin/env bash
# Pre-commit hook: block commits that contain hardcoded secrets
# Checks staged files only (not the full working tree)

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FAIL=0

# Patterns that indicate a real secret value (not just a reference to an env var)
# Each entry: "LABEL|REGEX"
PATTERNS=(
  "Anthropic API key|sk-ant-[a-zA-Z0-9_-]{20,}"
  "OpenAI API key|sk-[a-zA-Z0-9]{20,}"
  "Telegram bot token|[0-9]{8,10}:[a-zA-Z0-9_-]{35}"
  "Postgres URL with password|postgres(ql)?:\/\/[^:]+:[^@]{4,}@"
  "Hardcoded AUTH_SECRET|AUTH_SECRET\s*=\s*['\"][^'\"]{10,}['\"]"
  "Hardcoded ENCRYPTION_KEY|ENCRYPTION_KEY\s*=\s*['\"][^'\"]{10,}['\"]"
  "Hardcoded CRON_SECRET|CRON_SECRET\s*=\s*['\"][^'\"]{8,}['\"]"
  "Hardcoded ADMIN_SECRET|ADMIN_SECRET\s*=\s*['\"][^'\"]{8,}['\"]"
  "Hardcoded JWT secret|jwt\.sign\([^,]+,\s*['\"][^'\"]{8,}['\"]"
  "Env var with hardcoded fallback|process\.env\.\w+\s*\?\?\s*['\"][^'\"]{6,}['\"]"
  "Env var with hardcoded fallback|process\.env\.\w+\s*\|\|\s*['\"][^'\"]{6,}['\"]"
)

# Files to skip (binary, lock files, the example file, and this hook script itself)
SKIP_PATTERN="\.(png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|pdf|zip|lock)$|package-lock\.json$|yarn\.lock$|\.env\.example$|scripts/pre-commit$"

# Get staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED" ]; then
  exit 0
fi

for file in $STAGED; do
  # Skip binary and irrelevant files
  if echo "$file" | grep -qE "$SKIP_PATTERN"; then
    continue
  fi

  # Skip if file doesn't exist (deleted)
  if [ ! -f "$file" ]; then
    continue
  fi

  for entry in "${PATTERNS[@]}"; do
    label="${entry%%|*}"
    pattern="${entry##*|}"

    if git diff --cached -- "$file" | grep "^+" | grep -qE "$pattern"; then
      echo -e "${RED}BLOCKED: Possible secret detected${NC}"
      echo -e "  ${YELLOW}Type:${NC}  $label"
      echo -e "  ${YELLOW}File:${NC}  $file"
      echo -e "  ${YELLOW}Match:${NC} $(git diff --cached -- "$file" | grep "^+" | grep -oE "$pattern" | head -1 | sed 's/./*/g' | head -c 20)..."
      echo ""
      FAIL=1
    fi
  done
done

if [ "$FAIL" -eq 1 ]; then
  echo -e "${RED}Commit blocked.${NC} Remove hardcoded secrets and use environment variables instead."
  echo "See .env.example for the list of required env vars."
  echo ""
  echo "If this is a false positive, you can bypass with: git commit --no-verify"
  exit 1
fi

exit 0
