# Database (Neon PostgreSQL connection string)
DATABASE_URL=

# Anthropic — used for AI insights, payslip OCR, Telegram intent parsing
# Generate at console.anthropic.com
ANTHROPIC_API_KEY=

# Auth — sign JWT session cookies (generate: openssl rand -base64 32)
AUTH_SECRET=

# Encryption — AES-256-GCM key for KuCoin credentials at rest (generate: openssl rand -base64 32)
ENCRYPTION_KEY=

# Telegram Bot — token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram Webhook Secret — arbitrary secret registered with Telegram setWebhook
# (generate: openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=

# Cron Secret — protects /api/cron/* endpoints (generate: openssl rand -base64 32)
CRON_SECRET=

# Admin Secret — protects /api/admin/* endpoints (generate: openssl rand -base64 32)
ADMIN_SECRET=
